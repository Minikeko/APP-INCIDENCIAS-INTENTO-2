// Esquema de base de datos para la app de Gestión de Envíos

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERADOR
}

enum EstadoEnvio {
  EN_TRANSITO
  RETRASADO
  PERDIDO
  EN_INVESTIGACION
  ENCONTRADO
  MAL_ENTREGADO
  ENTREGADO
  DEVUELTO
  RESUELTO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  nombre       String
  passwordHash String
  role         Role     @default(OPERADOR)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  envios          Envio[]            @relation("CreadoPor")
  cambiosEstado   CambioEstado[]
  comentarios     Comentario[]
  documentosTarifa  DocumentoTarifa[]
  documentosFactura DocumentoFactura[]
  registrosActividad RegistroActividad[]
  denuncias       Denuncia[]
  gastos          Gasto[]
  chatsParticipante ChatParticipante[]
  mensajes        Mensaje[]
  archivosExcel   ArchivoExcel[]
}

model Envio {
  id              String   @id @default(cuid())
  numeroSeguimiento String @unique
  mensajero       String
  estado          EstadoEnvio @default(EN_TRANSITO)
  motivo          String?     // motivo del problema (ej. "extraviado en tránsito")
  descripcion     String?     @db.Text
  destinatario    String?
  direccion       String?
  fechaEnvio      DateTime?
  fechaInforme    DateTime?   // fecha en la que se informó de la incidencia
  ultimaActualizacion DateTime @updatedAt
  createdAt       DateTime @default(now())

  creadoPorId     String
  creadoPor       User     @relation("CreadoPor", fields: [creadoPorId], references: [id])

  cambiosEstado   CambioEstado[]
  adjuntos        Adjunto[]
  comentarios     Comentario[]
  denuncias       DenunciaEnvio[]

  @@index([estado])
  @@index([mensajero])
  @@index([numeroSeguimiento])
}

model CambioEstado {
  id          String      @id @default(cuid())
  envioId     String
  envio       Envio       @relation(fields: [envioId], references: [id], onDelete: Cascade)
  estadoAnterior EstadoEnvio?
  estadoNuevo EstadoEnvio
  nota        String?
  creadoPorId String
  creadoPor   User        @relation(fields: [creadoPorId], references: [id])
  createdAt   DateTime    @default(now())

  @@index([envioId])
}

model Comentario {
  id          String   @id @default(cuid())
  envioId     String
  envio       Envio    @relation(fields: [envioId], references: [id], onDelete: Cascade)
  texto       String   @db.Text
  creadoPorId String
  creadoPor   User     @relation(fields: [creadoPorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([envioId])
}

model Adjunto {
  id          String   @id @default(cuid())
  envioId     String
  envio       Envio    @relation(fields: [envioId], references: [id], onDelete: Cascade)
  nombreArchivo String
  tipoArchivo String   // mime type
  tamano      Int      // bytes
  datos       Bytes    // contenido del archivo guardado en la propia BD
  createdAt   DateTime @default(now())

  @@index([envioId])
}

// Documentos de tarifas de comerciales — solo accesible para administradores
model DocumentoTarifa {
  id            String   @id @default(cuid())
  nombreArchivo String
  tipoArchivo   String   // mime type
  tamano        Int      // bytes
  datos         Bytes    // contenido del archivo guardado en la propia BD
  mes           Int      // 1-12
  anio          Int
  comercial     String
  createdAt     DateTime @default(now())

  subidoPorId   String
  subidoPor     User     @relation(fields: [subidoPorId], references: [id])

  @@index([anio, mes])
  @@index([comercial])
}

// Documentos de facturación — solo accesible para administradores
model DocumentoFactura {
  id            String   @id @default(cuid())
  nombreArchivo String
  tipoArchivo   String   // mime type
  tamano        Int      // bytes
  datos         Bytes    // contenido del archivo guardado en la propia BD
  mes           Int      // 1-12
  anio          Int
  clienteProveedor String
  numeroFactura String?
  importe       Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  subidoPorId   String
  subidoPor     User     @relation(fields: [subidoPorId], references: [id])

  @@index([anio, mes])
  @@index([clienteProveedor])
}

enum TipoAccion {
  LOGIN
  ENVIO_CREADO
  ENVIO_EDITADO
  ENVIO_ELIMINADO
  ESTADO_CAMBIADO
  COMENTARIO_ANADIDO
  ADJUNTO_SUBIDO
  ADJUNTO_ELIMINADO
  USUARIO_CREADO
  USUARIO_ACTUALIZADO
  DOCUMENTO_SUBIDO
  DOCUMENTO_ELIMINADO
  DENUNCIA_CREADA
  DENUNCIA_ELIMINADA
  GASTO_SUBIDO
  GASTO_ELIMINADO
  CHAT_CREADO
}

// Registro de actividad — auditoría de acciones relevantes en la aplicación
model RegistroActividad {
  id          String     @id @default(cuid())
  tipo        TipoAccion
  descripcion String     // texto legible, ej. "Cambió el estado de ES4471829034 a Perdido"
  entidadId   String?    // id del envío/usuario/documento afectado, si aplica
  createdAt   DateTime   @default(now())

  usuarioId   String
  usuario     User       @relation(fields: [usuarioId], references: [id])

  @@index([tipo])
  @@index([usuarioId])
  @@index([createdAt])
}

// ===== Denuncias =====
// Sección independiente (solo administradores). Puede tener contenido escrito
// en la app (se genera PDF con membrete) o un PDF ya redactado subido a mano.
// Opcionalmente se enlaza a uno o varios envíos relacionados.

model Denuncia {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?  @db.Text   // contenido si se redacta en la app
  fecha       DateTime @default(now())

  // Si se sube un PDF ya redactado, se guarda aquí; si no, es null y el PDF
  // se genera al vuelo a partir de titulo/descripcion/fecha con el membrete.
  archivoOriginalNombre String?
  archivoOriginalTipo   String?
  archivoOriginalDatos  Bytes?

  createdAt   DateTime @default(now())

  creadoPorId String
  creadoPor   User     @relation(fields: [creadoPorId], references: [id])

  envios      DenunciaEnvio[]

  @@index([fecha])
}

// Tabla intermedia: una denuncia puede enlazar varios envíos y un envío
// puede aparecer en varias denuncias.
model DenunciaEnvio {
  id         String   @id @default(cuid())
  denunciaId String
  denuncia   Denuncia @relation(fields: [denunciaId], references: [id], onDelete: Cascade)
  envioId    String
  envio      Envio    @relation(fields: [envioId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([denunciaId, envioId])
  @@index([envioId])
}

enum CategoriaGasto {
  COMBUSTIBLE
  MATERIAL_SUMINISTROS
  MANTENIMIENTO_VEHICULOS
  DIETAS_DESPLAZAMIENTOS
  MATERIAL_OFICINA
  OTROS
}

// ===== Gastos varios =====
// Solo administradores suben los PDFs; se muestran con vista previa en lista.
model Gasto {
  id            String         @id @default(cuid())
  nombreArchivo String
  tipoArchivo   String         // mime type (siempre PDF en la práctica)
  tamano        Int            // bytes
  datos         Bytes          // contenido del archivo
  fecha         DateTime
  importe       Decimal        @db.Decimal(12, 2)
  categoria     CategoriaGasto
  descripcion   String?
  createdAt     DateTime       @default(now())

  subidoPorId   String
  subidoPor     User           @relation(fields: [subidoPorId], references: [id])

  @@index([fecha])
  @@index([categoria])
}

enum TipoChat {
  PRIVADO
  GRUPAL
}

// ===== Chats =====
// Chats privados o grupales entre usuarios. Los administradores pueden ver
// el contenido de cualquier chat (acceso de supervisión, no anunciado a los
// usuarios) a través de una ruta de API específica para administradores.
model Chat {
  id        String   @id @default(cuid())
  tipo      TipoChat
  nombre    String?  // solo relevante para chats grupales
  createdAt DateTime @default(now())

  participantes ChatParticipante[]
  mensajes      Mensaje[]
}

model ChatParticipante {
  id      String @id @default(cuid())
  chatId  String
  chat    Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
  @@index([userId])
}

model Mensaje {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  texto     String   @db.Text
  createdAt DateTime @default(now())

  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])

  @@index([chatId, createdAt])
}

// ===== Archivos Excel =====
// Sección para subir Excels tal cual, sin campos adicionales obligatorios.
// Solo administradores. Vista previa respetando el formato visual del archivo.
model ArchivoExcel {
  id            String   @id @default(cuid())
  nombreArchivo String
  tamano        Int      // bytes
  datos         Bytes
  descripcion   String?  // nombre o nota opcional que el usuario puede añadir
  createdAt     DateTime @default(now())

  subidoPorId   String
  subidoPor     User     @relation(fields: [subidoPorId], references: [id])

  @@index([createdAt])
}
